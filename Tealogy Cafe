    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: linear-gradient(180deg, #eae3d8 0%, #dfd5c6 30%, #d4c7b4 60%, #c4b6a1 100%);
            color: #2c1a11;
            overflow-x: hidden;
            scroll-behavior: smooth;
        }
        .serif-font {
            font-family: 'Playfair Display', serif;
        }
        /* Glassmorphism components */
        .glass-card {
            background: rgba(255, 255, 255, 0.35);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.4);
        }
        .glass-input {
            background: rgba(255, 255, 255, 0.25);
            border: 1px solid rgba(255, 255, 255, 0.4);
            color: #2c1a11;
        }
        .glass-input:focus {
            background: rgba(255, 255, 255, 0.45);
            outline: none;
            border-color: #4a2c1b;
        }
        /* Scroll Reveal Core Classes */
        .reveal {
            opacity: 0;
            transform: translateY(50px);
            transition: all 1.2s cubic-bezier(0.215, 0.610, 0.355, 1);
        }
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
        /* Continuous ambient animations */
        @keyframes float {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-12px) rotate(3deg); }
            100% { transform: translateY(0px) rotate(0deg); }
        }
        .floating-element {
            animation: float 7s ease-in-out infinite;
        }
        /* Image fade transition for showcase */
        .fade-img {
            transition: opacity 0.4s ease-in-out;
        }
        /* Custom Scrollbars */
        ::-webkit-scrollbar {
            width: 10px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.05);
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #4a2c1b;
            border-radius: 10px;
        }
        /* Hide scrollbar for clean slider views but keep functionality */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
