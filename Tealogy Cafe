    <!-- VANILLA JAVASCRIPT FOR DYNAMIC IMAGE COUPLING & SCROLL ANIMATIONS -->
    <script>
        // Image collection dictionary mapping keys to premium placeholder visual elements
        const imagesDB = {
            coffee: "https://images.unsplash.com/photo-1541167760496-1628856ab772?q=80&w=600&auto=format&fit=crop",
            tea: "https://images.unsplash.com/photo-1536256263959-770b48d82b0a?q=80&w=600&auto=format&fit=crop",
            cookie: "https://images.unsplash.com/photo-1499636136210-6f4ee915583e?q=80&w=600&auto=format&fit=crop",
            breakfast: "https://images.unsplash.com/photo-1525351484163-7529414344d8?q=80&w=600&auto=format&fit=crop"
        };

        function changeHeroImage(type, element) {
            const displayImg = document.getElementById('hero-showcase');
            
            // 1. Clear premium borders on tabs
            document.querySelectorAll('.hero-tab').forEach(btn => {
                btn.classList.remove('bg-white', 'border-[#4a2c1b]', 'scale-105', 'shadow-md');
                btn.classList.add('bg-white/40', 'border-white/20', 'shadow-sm');
            });

            // 2. Highlight selected tab element
            element.classList.remove('bg-white/40', 'border-white/20', 'shadow-sm');
            element.classList.add('bg-white', 'border-2', 'border-[#4a2c1b]', 'scale-105', 'shadow-md');

            // 3. Dynamic fade cross-over transition trigger
            displayImg.style.opacity = '0';
            setTimeout(() => {
                displayImg.src = imagesDB[type];
                displayImg.style.opacity = '1';
            }, 300);
        }

        // Standard reveal calculation framework
        function revealOnScroll() {
            const reveals = document.querySelectorAll('.reveal');
            reveals.forEach(reveal => {
                const windowHeight = window.innerHeight;
                const elementTop = reveal.getBoundingClientRect().top;
                const elementVisible = 100;
                if (elementTop < windowHeight - elementVisible) {
                    reveal.classList.add('active');
                }
            });
        }

        window.addEventListener('DOMContentLoaded', revealOnScroll);
        window.addEventListener('scroll', revealOnScroll);
    </script>
